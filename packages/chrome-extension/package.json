{
  "name": "@rsc-parser/chrome-extension",
  "version": "1.1.2",
  "license": "MIT",
  "packageManager": "bun@1.3.3",
  "private": true,
  "dependencies": {
    "@rsc-parser/core": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2"
  },
  "devDependencies": {
    "@ariakit/react": "0.4.30",
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "chrome-types": "0.1.433",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "type-fest": "5.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.3",
    "vite-plugin-html-config": "2.0.2"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier . --check --config ../../.prettierrc",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --mode development && vite dev",
    "build": "vite build && sed -i'.backup' 's| http://localhost:6020||g' dist/manifest.json && rm dist/manifest.json.backup",
    "clean": "rm -rf dist"
  },
  "type": "module"
}
